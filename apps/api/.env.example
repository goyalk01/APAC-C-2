# SwarmGuard API — environment configuration example.
# Copy to .env for local dev: cp .env.example .env

# --- Service identity ---
API_HOST=0.0.0.0
API_PORT=8010

# --- Mesh relay (upstream WS source this service connects to as a client) ---
MESH_RELAY_URL=ws://localhost:8765

# --- Storage (leave unset to use the default relative paths) ---
# SQLITE_PATH=./swarm_cache.db
# NODE_KEYS_PATH=./node_keys.json

# --- CORS — comma-separated list of allowed frontend origins ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Optional shared API-key auth (Decision 1) ---
# Leave unset/empty to disable auth (dev default).
# Set to a strong random value to enable auth for staging/prod.
# SWARMBOX_API_KEY=

# --- Logging ---
LOG_LEVEL=INFO
