# ============================================================
# SwarmGuard AI — .gitignore
# ============================================================

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
htmlcov/
*.cover
*.egg-info/
dist/
build/
*.egg

# ----- Virtual Environments -----
venv/
.venv/
env/
.env/

# ----- Node / Next.js -----
node_modules/
.next/
out/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
*.tsbuildinfo
next-env.d.ts
.vercel

# ----- IDE / Editor -----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Environment Files -----
.env
.env.*
!.env.example
!.env.local.example

# ----- Runtime / Generated Files -----
apps/api/swarm_cache.db
apps/api/node_keys.json
*.db
*.sqlite3

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- OS Files -----
.DS_Store
Desktop.ini
ehthumbs.db

# ----- Docker -----
docker-compose.override.yml

# ----- Secrets / Keys -----
*.pem
*.key
